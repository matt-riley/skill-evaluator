---
import Layout from '../layouts/Layout.astro';
import { buildNavLinks, cleanPath } from '../utils/routing';

export async function getStaticPaths() {
  const rootDocs = import.meta.glob('../../../../*.md', { eager: true });
  const adrDocs = import.meta.glob('../../../../docs/adr/*.md', { eager: true });

  const allFilesRaw = { ...rootDocs, ...adrDocs };

  // Filter out agent instruction files from the documentation
  const allFiles = Object.keys(allFilesRaw).reduce((acc, key) => {
    const lowerKey = key.toLowerCase();
    if (
      !lowerKey.endsWith('agents.md') && 
      !lowerKey.endsWith('claude.md') && 
      !lowerKey.endsWith('context.md')
    ) {
      acc[key] = allFilesRaw[key];
    }
    return acc;
  }, {});

  const paths = [];

  for (const key of Object.keys(allFiles)) {
    const doc = allFiles[key];
    const relativePath = cleanPath(key).toLowerCase();
      
    let slug = relativePath;
    if (slug === 'readme') {
      slug = undefined;
    }

    const navLinks = buildNavLinks(Object.keys(allFiles), slug || 'readme');

    paths.push({
      params: { slug },
      props: { doc, navLinks }
    });
  }
  
  return paths;
}

const { doc, navLinks } = Astro.props;
const Content = doc.default || doc.Content || doc;

let { slug } = Astro.params;
if (!slug || slug === '') slug = 'README';

const isAnyAdrActive = navLinks.some(link => link.isAdr && link.isActive);
---
<Layout title={doc.frontmatter?.title || slug}>
  <div class="flex min-h-screen text-black font-sans selection:bg-neo-pink selection:text-white">
    <!-- Sidebar -->
    <aside class="w-80 bg-neo-yellow border-r-4 border-black p-6 hidden md:flex flex-col shrink-0 overflow-y-auto h-screen sticky top-0 z-20">
      <div class="mb-10 flex items-center gap-4 group cursor-pointer">
        <div class="size-14 rounded-3xl bg-neo-pink border-4 border-black flex items-center justify-center shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] group-hover:-translate-y-1 group-hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] transition-all">
          <span class="text-white font-black text-2xl -rotate-6 group-hover:rotate-6 transition-transform">SE</span>
        </div>
        <a href="/" class="text-3xl font-black text-black tracking-tight group-hover:scale-105 transition-transform origin-left">Skill Eval</a>
      </div>
      
      <div class="space-y-8 flex-1">
        <div>
          <h3 class="text-sm font-black tracking-widest text-black/60 uppercase mb-4 px-2">Documentation 📚</h3>
          <ul class="space-y-4">
            {navLinks.filter(link => !link.isAdr).map(link => (
              <li>
                <a 
                  href={`/${link.path === 'readme' ? '' : link.path}`} 
                  class={`block text-lg px-5 py-3 rounded-2xl transition-all duration-300 font-bold border-4 border-black ${
                    link.isActive 
                      ? 'bg-neo-blue text-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] -translate-y-1 rotate-1' 
                      : 'bg-white text-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:-rotate-1'
                  }`}
                >
                  {link.title === 'Readme' ? '👋 Introduction' : `✨ ${link.title}`}
                </a>
              </li>
            ))}
          </ul>
        </div>
        
        <details class="group" open={isAnyAdrActive}>
          <summary class="text-sm font-black tracking-widest text-black/60 uppercase mb-4 px-2 cursor-pointer list-none flex justify-between items-center hover:text-black transition-colors">
            Arch Decisions 🏗️
            <span class="transform group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <ul class="space-y-4 mt-2">
            {navLinks.filter(link => link.isAdr).map(link => (
              <li>
                <a 
                  href={`/${link.path}`} 
                  class={`block text-lg px-5 py-3 rounded-2xl transition-all duration-300 font-bold truncate border-4 border-black ${
                    link.isActive 
                      ? 'bg-neo-green text-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] -translate-y-1 -rotate-1' 
                      : 'bg-white text-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:rotate-1'
                  }`}
                  title={link.title}
                >
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </details>
      </div>
    </aside>

    <!-- Mobile header -->
    <div class="md:hidden fixed top-0 left-0 right-0 h-20 border-b-4 border-black bg-neo-yellow z-30 flex items-center px-6">
      <div class="size-12 rounded-2xl bg-neo-pink border-4 border-black flex items-center justify-center shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] mr-4">
        <span class="text-white font-black text-lg -rotate-6">SE</span>
      </div>
      <a href="/" class="text-3xl font-black text-black tracking-tight">Skill Eval</a>
    </div>

    <!-- Main Content -->
    <main class="flex-1 w-full max-w-4xl mx-auto px-6 py-28 md:py-20 md:px-16 relative overflow-x-hidden min-h-screen">
      
      <div class="bg-white border-4 border-black rounded-[3rem] p-8 md:p-16 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] md:shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] relative z-10 mb-20">
        <article class="docs-prose">
          <Content />
        </article>
      </div>
    </main>
  </div>
</Layout>
