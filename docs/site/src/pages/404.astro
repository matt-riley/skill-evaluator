---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404: Page Not Found">
  <div class="flex min-h-screen text-black font-sans selection:bg-neo-pink selection:text-white bg-[#f8f9fa] items-center justify-center p-6 relative overflow-hidden">
    
    <!-- Decorative elements in background -->
    <div class="absolute -top-10 -left-10 w-40 h-40 bg-neo-yellow border-4 border-black rounded-full shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] -z-0 hidden md:block"></div>
    <div class="absolute bottom-20 -right-5 w-32 h-32 bg-neo-green border-4 border-black rounded-3xl rotate-12 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] -z-0 hidden md:block"></div>
    
    <main class="w-full max-w-3xl mx-auto relative z-10 text-center">
      <div class="bg-white border-4 border-black rounded-[3rem] p-10 md:p-16 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] md:shadow-[16px_16px_0px_0px_rgba(0,0,0,1)]">
        
        <div class="inline-block bg-neo-yellow border-4 border-black rounded-3xl px-8 py-4 mb-8 -rotate-2 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)]">
          <h1 class="text-6xl md:text-8xl font-black tracking-tight text-black">404</h1>
        </div>
        
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-black mb-6">
          Oops! This page wandered off. 🕵️‍♂️
        </h2>
        
        <p class="text-xl md:text-2xl font-bold text-gray-800 mb-10 max-w-xl mx-auto leading-relaxed">
          The link you followed might be broken, or the page may have been removed. Let's get you back on track.
        </p>
        
        <a href="/" class="inline-block bg-neo-pink text-white font-black text-xl md:text-2xl px-8 py-4 rounded-2xl border-4 border-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-2 hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all">
          ← Back to Home
        </a>
      </div>
    </main>
  </div>
</Layout>
